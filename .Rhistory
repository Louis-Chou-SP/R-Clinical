pkgs <- c(
"tidyverse", "haven", "lubridate",
"sdtm.oak", "metatools",
"admiral",
"rtables", "ggplot2", "rlistings",
"xportr", "metacore",
"renv", "quarto"
)
data.frame(
Package   = pkgs,
Installed = pkgs %in% rownames(installed.packages())
)
R.version.string
