"002", "002", "002"),
PARAMCD = c("ALT", "ALT", "ALT", "ALT",
"ALT", "ALT", "ALT"),
AVISIT  = c("Baseline", "Week 4", "Week 8", "Week 12",
"Baseline", "Week 4", "Week 8"),
AVAL    = c(30, 45, 38, 50,
25, 20, 28)
)
adlb_practice
result <- adlb_practice %>%
group_by(USUBJID, PARAMCD) %>%
arrange(USUBJID, AVAL) %>%
mutate(
PREV_AVAL = lag(AVAL)
)
reuslt
result
result <- adlb_practice %>%
mutate(
AVISITN = case_when(
AVISIT == "Baseline" ~ 0,
AVISIT == "Week 4" ~ 4,
AVISIT == "Week 8" ~ 8,
TRUE ~ 999
)
) %>%
arrange(USUBJID, PARAMCD, AVISITN) %>%
group_by(USUBJID, PARAMCD) %>%
mutate(
BASE = first(AVAL),
CHG = AVAL - BASE,
PCHG = CHG / BASE * 100,
PREV_AVAL = lag(AVAL)
) %>%
ungroup()
result
View(resutl3)
View(result)
View(result)
