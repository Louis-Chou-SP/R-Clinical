library(dplyr)
# 用 adsl 概念建立測試資料
adsl_test <- data.frame(
USUBJID = paste0("S", 1:6),
TRT01P  = c("Drug A", "Drug A", "Drug A",
"Placebo", "Placebo", "Placebo"),
AGE     = c(45, 52, 63, 41, 55, 70)
)
# ===== 有 ungroup =====
result_ungrouped <- adsl_test %>%
group_by(TRT01P) %>%
mutate(mean_age = mean(AGE)) %>%
ungroup() %>%
mutate(pct_of_total = AGE / sum(AGE) * 100)
# pct_of_total 分母 = 全部 6 人的 AGE 總和
# ===== 沒有 ungroup =====
result_grouped <- adsl_test %>%
group_by(TRT01P) %>%
mutate(mean_age = mean(AGE)) %>%
mutate(pct_of_total = AGE / sum(AGE) * 100)
# pct_of_total 分母 = 各組自己的 AGE 總和
# 比較結果
result_ungrouped %>% select(USUBJID, TRT01P, AGE, pct_of_total)
result_grouped   %>% select(USUBJID, TRT01P, AGE, pct_of_total)
View(result_grouped)
View(result_ungrouped)
"2024-01-15" %>% as.Date() %>% format("%Y/%m/%d")
"AESTDTC" %>% tolower()
library(dplyr)
adsl_test <- data.frame(
USUBJID = paste0("S", 1:6),
TRT01P  = c("Drug A", "Drug A", "Drug A",
"Placebo", "Placebo", "Placebo"),
AGEGR1  = c("< 65", ">= 65", "< 65",
">= 65", "< 65", ">= 65"),
AGE     = c(45, 63, 52, 70, 41, 55)
)
result <- adsl_test %>%
# 第一層：算各治療組平均年齡
group_by(TRT01P) %>%
mutate(trt_mean_age = mean(AGE)) %>%
ungroup() %>%
# 第二層：算各治療組 x 年齡組的人數
group_by(TRT01P, AGEGR1) %>%
mutate(subgrp_n = n()) %>%
ungroup() %>%
# 最後：算全體百分比並排序
mutate(pct_of_total = AGE / sum(AGE) * 100) %>%
arrange(TRT01P, AGE)
result
View(adsl_test)
View(result)
